{
  "name": "@graphen/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "phase0:pg": "tsx src/scripts/runMemoryPhase0.ts",
    "phase1:pg": "tsx src/scripts/runMemoryPhase1.ts",
    "phase2:pg": "tsx src/scripts/runMemoryPhase2.ts",
    "phase3:pg": "tsx src/scripts/runMemoryPhase3.ts",
    "phase4:pg": "tsx src/scripts/runMemoryPhase4.ts",
    "phase5:pg": "tsx src/scripts/runMemoryPhase5.ts",
    "phase6:pg": "tsx src/scripts/runMemoryPhase6.ts",
    "phase7:pg": "tsx src/scripts/runMemoryPhase7.ts",
    "prompt:eval": "tsx src/scripts/runPromptEval.ts",
    "prompt:compare": "tsx src/scripts/runPromptEvalComparison.ts",
    "prompt:weekly": "tsx src/scripts/runPromptWeeklyReport.ts",
    "memory:backfill-evidence-hash": "tsx src/scripts/backfillMemoryEvidenceHash.ts",
    "migrate:pg": "tsx src/scripts/migrate-to-pg.ts",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration"
  },
  "dependencies": {
    "@graphen/shared": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "file-type": "^19.6.0",
    "langchain": "^0.3.11",
    "multer": "^2.0.2",
    "neo4j-driver": "^5.26.0",
    "openai": "^4.86.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.3",
    "pino": "^9.6.0",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.4",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.3",
    "fast-check": "^4.5.3",
    "supertest": "^7.2.2",
    "testcontainers": "^10.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
