NODE_ENV=development

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173
MAX_UPLOAD_SIZE=52428800
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
LOG_LEVEL=info
GRAPH_SYNC_ENABLED=true
RUNTIME_PG_REQUIRED=true
CACHE_DIR=data/cache
CHUNK_SIZE=1500
CHUNK_OVERLAP=200
MAX_CHUNKS_PER_DOCUMENT=500
MAX_DOCUMENT_ESTIMATED_TOKENS=500000

# LLM Provider Selection (gemini, qwen, or openai)
LLM_PROVIDER=gemini

# Gemini Configuration
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_CHAT_MODEL=gemini-3-flash-preview
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Qwen Configuration
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-max
QWEN_EMBEDDING_MODEL=text-embedding-v3

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Prompt Version Overrides (optional; leave empty to use defaults in versions.ts)
PROMPT_VERSION_ANALYSIS=
PROMPT_VERSION_CHAT=
PROMPT_VERSION_MEMORY=

# LLM — Embedding (optional, separate provider for embeddings)
# Leave empty to use the same provider as chat
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
LLM_MAX_CONCURRENT=5
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY_MS=1000
LLM_REQUESTS_PER_MINUTE=30
LLM_TIMEOUT_MS=120000
EMBEDDING_DIMENSIONS=1024

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# PostgreSQL (Primary Storage)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=graphen
PG_USER=graphen
PG_PASSWORD=
PG_MAX_CONNECTIONS=20
PG_AUTO_BOOTSTRAP=true
PG_BOOTSTRAP_DATABASE=postgres
# Optional: if empty, backend will try PGUSER/USER/current PG_USER
PG_BOOTSTRAP_USER=
PG_BOOTSTRAP_PASSWORD=
PG_VECTOR_HNSW_M=16
PG_VECTOR_HNSW_EF_CONSTRUCTION=200
PG_VECTOR_EF_SEARCH=64
MEMORY_FACTS_COMPAT_STAGE=stage1
MEMORY_FACTS_COMPAT_ALLOWLIST=graphen-frontend,graphen-internal
MEMORY_REWRITE_ENABLED=true
MEMORY_REWRITE_POLL_INTERVAL_MS=2000
MEMORY_REWRITE_MAX_RETRIES=3
MEMORY_REWRITE_BASE_BACKOFF_MS=5000
MEMORY_REWRITE_USE_LLM=false
